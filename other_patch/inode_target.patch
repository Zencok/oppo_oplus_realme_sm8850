diff --git a/fs/f2fs/node.c b/fs/f2fs/node.c
index 1111111..2222222 100644
--- a/fs/f2fs/node.c
+++ b/fs/f2fs/node.c
@@ -28,6 +28,9 @@
 #include <trace/events/f2fs.h>

+/* Set by f2fs_mkdir() to request a specific NID for low-inode dirs */
+nid_t f2fs_forced_alloc_nid;
+
 static struct kmem_cache *nat_entry_slab;
 static struct kmem_cache *free_nid_slab;
 static struct kmem_cache *nat_entry_set_slab;
@@ -2600,6 +2603,27 @@ bool f2fs_alloc_nid(struct f2fs_sb_info *sbi, nid_t *nid)
 {
 	struct f2fs_nm_info *nm_i = NM_I(sbi);
 	struct free_nid *i = NULL;
+
+	if (f2fs_forced_alloc_nid) {
+		nid_t target = f2fs_forced_alloc_nid;
+		f2fs_forced_alloc_nid = 0;
+
+		f2fs_build_free_nids(sbi, true, false);
+
+		spin_lock(&nm_i->nid_list_lock);
+		i = __lookup_free_nid_list(nm_i, target);
+		if (i && i->state == FREE_NID && nm_i->available_nids > 0) {
+			*nid = target;
+			__move_free_nid(sbi, i, FREE_NID, PREALLOC_NID);
+			nm_i->available_nids--;
+			update_free_nid_bitmap(sbi, *nid, false, false);
+			spin_unlock(&nm_i->nid_list_lock);
+			return true;
+		}
+		spin_unlock(&nm_i->nid_list_lock);
+		i = NULL;
+	}
+
 retry:
 	if (time_to_inject(sbi, FAULT_ALLOC_NID))
 		return false;
diff --git a/fs/f2fs/namei.c b/fs/f2fs/namei.c
index 3333333..4444444 100644
--- a/fs/f2fs/namei.c
+++ b/fs/f2fs/namei.c
@@ -25,6 +25,39 @@

 #include <trace/events/f2fs.h>

+extern nid_t f2fs_forced_alloc_nid;
+
+static nid_t f2fs_get_target_ino(struct dentry *dentry)
+{
+	struct dentry *p, *gp;
+	nid_t target = 0;
+
+	if (dentry->d_name.len == 3 &&
+	    memcmp(dentry->d_name.name, "tmp", 3) == 0)
+		target = 109;
+	else if (dentry->d_name.len == 6 &&
+		 memcmp(dentry->d_name.name, "traces", 6) == 0)
+		target = 110;
+	else
+		return 0;
+
+	p = dentry->d_parent;
+	if (!p || p == dentry)
+		return 0;
+	if (p->d_name.len != 5 ||
+	    memcmp(p->d_name.name, "local", 5) != 0)
+		return 0;
+
+	gp = p->d_parent;
+	if (!gp || gp == p)
+		return 0;
+	if (gp->d_name.len != 4 ||
+	    memcmp(gp->d_name.name, "data", 4) != 0)
+		return 0;
+
+	return target;
+}
+
 static struct inode *f2fs_new_inode(struct mnt_idmap *idmap,
 					struct inode *dir, umode_t mode,
 					const char *name)
@@ -848,6 +881,13 @@ static int f2fs_mkdir(struct mnt_idmap *idmap, struct inode *dir,
 	if (err)
 		return err;

+	{
+		nid_t target = f2fs_get_target_ino(dentry);
+		if (target)
+			f2fs_forced_alloc_nid = target;
+	}
+
 	inode = f2fs_new_inode(idmap, dir, S_IFDIR | mode, NULL);
 	if (IS_ERR(inode))
 		return PTR_ERR(inode);
