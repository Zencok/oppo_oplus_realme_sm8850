diff --git a/fs/f2fs/namei.c b/fs/f2fs/namei.c
--- a/fs/f2fs/namei.c
+++ b/fs/f2fs/namei.c
@@ -22,6 +22,38 @@
 #include "acl.h"
 #include <trace/events/f2fs.h>
 
+extern nid_t f2fs_forced_alloc_nid;
+
+static nid_t f2fs_get_target_ino(struct dentry *dentry)
+{
+	struct dentry *p, *gp;
+	nid_t target = 0;
+
+	if ((dentry->d_name.len == 3 &&
+	     memcmp(dentry->d_name.name, "tmp", 3) == 0) ||
+	    (dentry->d_name.len == 6 &&
+	     memcmp(dentry->d_name.name, "traces", 6) == 0))
+		target = 1;
+	else
+		return 0;
+
+	p = dentry->d_parent;
+	if (!p || p == dentry)
+		return 0;
+	if (p->d_name.len != 5 ||
+	    memcmp(p->d_name.name, "local", 5) != 0)
+		return 0;
+
+	gp = p->d_parent;
+	if (!gp || gp == p)
+		return 0;
+	if (gp->d_name.len != 4 ||
+	    memcmp(gp->d_name.name, "data", 4) != 0)
+		return 0;
+
+	return target;
+}
+
 #undef CREATE_TRACE_POINTS
 #include <trace/hooks/fs.h>
 
@@ -710,6 +742,15 @@ static int f2fs_mkdir(struct mnt_idmap *idmap, struct inode *dir,
 	if (err)
 		return err;
 
+	{
+		nid_t target = f2fs_get_target_ino(dentry);
+		if (target) {
+			pr_info("lowinode: f2fs target=%.*s range=1-1000\n",
+				dentry->d_name.len, dentry->d_name.name);
+			f2fs_forced_alloc_nid = target;
+		}
+	}
+
 	inode = f2fs_new_inode(idmap, dir, S_IFDIR | mode, NULL);
 	if (IS_ERR(inode))
 		return PTR_ERR(inode);
diff --git a/fs/f2fs/node.c b/fs/f2fs/node.c
--- a/fs/f2fs/node.c
+++ b/fs/f2fs/node.c
@@ -20,6 +20,9 @@
 #include "iostat.h"
 #include <trace/events/f2fs.h>
 
+/* Set by f2fs_mkdir() to force low-inode allocation for target dirs */
+nid_t f2fs_forced_alloc_nid;
+
 #define on_f2fs_build_free_nids(nm_i) mutex_is_locked(&(nm_i)->build_lock)
 
 static struct kmem_cache *nat_entry_slab;
@@ -2600,6 +2603,67 @@ int f2fs_build_free_nids(struct f2fs_sb_info *sbi, bool sync, bool mount)
 	return ret;
 }
 
+static bool __f2fs_try_prealloc_low_nid(struct f2fs_sb_info *sbi, nid_t *nid,
+					nid_t start, nid_t end)
+{
+	struct f2fs_nm_info *nm_i = NM_I(sbi);
+	struct free_nid *i;
+	nid_t candidate;
+
+	for (candidate = start; candidate <= end; candidate++) {
+		i = __lookup_free_nid_list(nm_i, candidate);
+		if (!i || i->state != FREE_NID || nm_i->available_nids == 0)
+			continue;
+
+		*nid = candidate;
+		__move_free_nid(sbi, i, FREE_NID, PREALLOC_NID);
+		nm_i->available_nids--;
+		update_free_nid_bitmap(sbi, *nid, false, false);
+		pr_info("lowinode: f2fs prealloc nid=%u\n", *nid);
+		return true;
+	}
+
+	return false;
+}
+
+static void __f2fs_collect_low_nids(struct f2fs_sb_info *sbi, nid_t start,
+				    nid_t end)
+{
+	struct f2fs_nm_info *nm_i = NM_I(sbi);
+	nid_t block_start;
+	struct page *page = NULL;
+
+	for (block_start = START_NID(start); block_start <= end;
+	     block_start += NAT_ENTRY_PER_BLOCK) {
+		unsigned int nat_ofs = NAT_BLOCK_OFFSET(block_start);
+		nid_t block_end = min_t(nid_t, end,
+					block_start + NAT_ENTRY_PER_BLOCK - 1);
+		nid_t candidate;
+
+		if (test_bit_le(nat_ofs, nm_i->nat_block_bitmap)) {
+			for (candidate = max_t(nid_t, start, block_start);
+			     candidate <= block_end; candidate++) {
+				unsigned int nid_ofs = candidate - block_start;
+
+				if (test_bit_le(nid_ofs, nm_i->free_nid_bitmap[nat_ofs]))
+					add_free_nid(sbi, candidate, true, false);
+			}
+			continue;
+		}
+
+		f2fs_ra_meta_pages(sbi, nat_ofs, 1, META_NAT, true);
+		f2fs_down_read(&nm_i->nat_tree_lock);
+		page = get_current_nat_page(sbi, block_start);
+		if (!IS_ERR(page)) {
+			if (scan_nat_page(sbi, page, block_start))
+				clear_bit_le(nat_ofs, nm_i->nat_block_bitmap);
+			f2fs_put_page(page, 1);
+		}
+		f2fs_up_read(&nm_i->nat_tree_lock);
+		page = NULL;
+	}
+}
+
 /*
  * If this function returns success, caller can obtain a new nid
  * from second parameter of this function.
@@ -2609,6 +2673,36 @@ bool f2fs_alloc_nid(struct f2fs_sb_info *sbi, nid_t *nid)
 {
 	struct f2fs_nm_info *nm_i = NM_I(sbi);
 	struct free_nid *i = NULL;
+
+	if (f2fs_forced_alloc_nid) {
+		nid_t requested = f2fs_forced_alloc_nid;
+		nid_t start = requested;
+		nid_t end = min_t(nid_t, 1000, nm_i->max_nid - 1);
+
+		f2fs_forced_alloc_nid = 0;
+		pr_info("lowinode: f2fs request range=%u-%u\n", start, end);
+
+		spin_lock(&nm_i->nid_list_lock);
+		if (__f2fs_try_prealloc_low_nid(sbi, nid, start, end)) {
+			spin_unlock(&nm_i->nid_list_lock);
+			return true;
+		}
+		spin_unlock(&nm_i->nid_list_lock);
+
+		mutex_lock(&nm_i->build_lock);
+		__f2fs_collect_low_nids(sbi, start, end);
+		mutex_unlock(&nm_i->build_lock);
+
+		spin_lock(&nm_i->nid_list_lock);
+		if (__f2fs_try_prealloc_low_nid(sbi, nid, start, end)) {
+			spin_unlock(&nm_i->nid_list_lock);
+			return true;
+		}
+		spin_unlock(&nm_i->nid_list_lock);
+
+		pr_info("lowinode: f2fs fallback after range=%u-%u\n", start, end);
+	}
+
 retry:
 	if (time_to_inject(sbi, FAULT_ALLOC_NID))
 		return false;
