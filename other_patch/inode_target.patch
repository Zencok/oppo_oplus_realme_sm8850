+/*
+ * f2fs_alloc_target_nid - Try to allocate a specific NID.
+ * @start: first NID to try
+ * @end:   last NID to try (inclusive)
+ *
+ * Scans [start, end] for a free NID. If found, reserves it
+ * (moves to PREALLOC_NID state) and returns true.
+ * The caller must later call f2fs_alloc_nid_done() on success
+ * or f2fs_alloc_nid_failed() on failure.
+ */
+bool f2fs_alloc_target_nid(struct f2fs_sb_info *sbi, nid_t *nid,
+			   nid_t start, nid_t end)
+{
+	struct f2fs_nm_info *nm_i = NM_I(sbi);
+	struct free_nid *fn;
+	nid_t target;
+
+	if (start < 1)
+		start = 1;
+	if (end < start)
+		return false;
+
+	/* Ensure free NID pool is populated */
+	if (nm_i->nid_cnt[FREE_NID] == 0)
+		f2fs_build_free_nids(sbi, true, false);
+
+	spin_lock(&nm_i->nid_list_lock);
+
+	if (unlikely(nm_i->available_nids == 0))
+		goto out_unlock;
+
+	for (target = start; target <= end; target++) {
+		fn = __lookup_free_nid_list(nm_i, target);
+		if (!fn || fn->state != FREE_NID)
+			continue;
+
+		*nid = target;
+		__move_free_nid(sbi, fn, FREE_NID, PREALLOC_NID);
+		nm_i->available_nids--;
+		update_free_nid_bitmap(sbi, *nid, false, false);
+		spin_unlock(&nm_i->nid_list_lock);
+		return true;
+	}
+
+out_unlock:
+	spin_unlock(&nm_i->nid_list_lock);
+
+	/* Low NIDs might not be in pool yet; rebuild and retry once */
+	f2fs_build_free_nids(sbi, true, false);
+
+	spin_lock(&nm_i->nid_list_lock);
+	for (target = start; target <= end; target++) {
+		fn = __lookup_free_nid_list(nm_i, target);
+		if (!fn || fn->state != FREE_NID)
+			continue;
+
+		*nid = target;
+		__move_free_nid(sbi, fn, FREE_NID, PREALLOC_NID);
+		nm_i->available_nids--;
+		update_free_nid_bitmap(sbi, *nid, false, false);
+		spin_unlock(&nm_i->nid_list_lock);
+		return true;
+	}
+	spin_unlock(&nm_i->nid_list_lock);
+
+	return false;
+}
