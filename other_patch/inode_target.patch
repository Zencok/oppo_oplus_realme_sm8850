+/*
+ * Check if a dentry matches /data/local/tmp or /data/local/traces.
+ * Returns target inode number (109 for tmp, 110 for traces), or 0 if no match.
+ */
+static nid_t f2fs_get_target_ino(struct dentry *dentry)
+{
+	struct dentry *parent, *grandparent;
+	const char *name = dentry->d_name.name;
+	unsigned int len = dentry->d_name.len;
+	nid_t target = 0;
+
+	/* Check leaf name: "tmp" -> 109, "traces" -> 110 */
+	if (len == 3 && memcmp(name, "tmp", 3) == 0)
+		target = 109;
+	else if (len == 6 && memcmp(name, "traces", 6) == 0)
+		target = 110;
+	else
+		return 0;
+
+	/* Check parent: "local" */
+	parent = dentry->d_parent;
+	if (!parent || parent == dentry)
+		return 0;
+	if (parent->d_name.len != 5 ||
+	    memcmp(parent->d_name.name, "local", 5) != 0)
+		return 0;
+
+	/* Check grandparent: "data" */
+	grandparent = parent->d_parent;
+	if (!grandparent || grandparent == parent)
+		return 0;
+	if (grandparent->d_name.len != 4 ||
+	    memcmp(grandparent->d_name.name, "data", 4) != 0)
+		return 0;
+
+	return target;
+}
