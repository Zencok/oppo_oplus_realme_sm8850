@@ -20,6 +20,9 @@
 #include "iostat.h"
 #include <trace/events/f2fs.h>
 
+nid_t f2fs_forced_alloc_nid;
+struct task_struct *f2fs_forced_alloc_task;
+
 #define on_f2fs_build_free_nids(nm_i) mutex_is_locked(&(nm_i)->build_lock)
 
 static struct kmem_cache *nat_entry_slab;
@@ -2600,6 +2603,50 @@ int f2fs_build_free_nids(struct f2fs_sb_info *sbi, bool sync, bool mount)
 	return ret;
 }
 
+static bool __f2fs_try_prealloc_exact_nid(struct f2fs_sb_info *sbi, nid_t *nid,
+					  nid_t candidate)
+{
+	struct f2fs_nm_info *nm_i = NM_I(sbi);
+	struct free_nid *i;
+
+	i = __lookup_free_nid_list(nm_i, candidate);
+	if (!i || i->state != FREE_NID || nm_i->available_nids == 0)
+		return false;
+
+	*nid = candidate;
+	__move_free_nid(sbi, i, FREE_NID, PREALLOC_NID);
+	nm_i->available_nids--;
+	update_free_nid_bitmap(sbi, *nid, false, false);
+	pr_info("lowinode: reserved exact nid=%u\n", *nid);
+	return true;
+}
+
+static void __f2fs_collect_exact_nid(struct f2fs_sb_info *sbi, nid_t candidate)
+{
+	struct f2fs_nm_info *nm_i = NM_I(sbi);
+	nid_t block_start = START_NID(candidate);
+	unsigned int nat_ofs = NAT_BLOCK_OFFSET(block_start);
+	struct page *page = NULL;
+
+	if (test_bit_le(nat_ofs, nm_i->nat_block_bitmap)) {
+		unsigned int nid_ofs = candidate - block_start;
+
+		if (test_bit_le(nid_ofs, nm_i->free_nid_bitmap[nat_ofs]))
+			add_free_nid(sbi, candidate, true, false);
+		return;
+	}
+
+	f2fs_ra_meta_pages(sbi, nat_ofs, 1, META_NAT, true);
+	f2fs_down_read(&nm_i->nat_tree_lock);
+	page = get_current_nat_page(sbi, block_start);
+	if (!IS_ERR(page)) {
+		if (scan_nat_page(sbi, page, block_start))
+			clear_bit_le(nat_ofs, nm_i->nat_block_bitmap);
+		f2fs_put_page(page, 1);
+	}
+	f2fs_up_read(&nm_i->nat_tree_lock);
+}
+
 /*
  * If this function returns success, caller can obtain a new nid
  * from second parameter of this function.
@@ -2609,6 +2656,34 @@ bool f2fs_alloc_nid(struct f2fs_sb_info *sbi, nid_t *nid)
 {
 	struct f2fs_nm_info *nm_i = NM_I(sbi);
 	struct free_nid *i = NULL;
+
+	if (f2fs_forced_alloc_nid && f2fs_forced_alloc_task == current) {
+		nid_t requested = f2fs_forced_alloc_nid;
+
+		f2fs_forced_alloc_nid = 0;
+		pr_info("lowinode: request exact nid=%u\n", requested);
+
+		spin_lock(&nm_i->nid_list_lock);
+		if (__f2fs_try_prealloc_exact_nid(sbi, nid, requested)) {
+			spin_unlock(&nm_i->nid_list_lock);
+			return true;
+		}
+		spin_unlock(&nm_i->nid_list_lock);
+
+		mutex_lock(&nm_i->build_lock);
+		__f2fs_collect_exact_nid(sbi, requested);
+		mutex_unlock(&nm_i->build_lock);
+
+		spin_lock(&nm_i->nid_list_lock);
+		if (__f2fs_try_prealloc_exact_nid(sbi, nid, requested)) {
+			spin_unlock(&nm_i->nid_list_lock);
+			return true;
+		}
+		spin_unlock(&nm_i->nid_list_lock);
+
+		pr_info("lowinode: exact nid unavailable=%u\n", requested);
+		return false;
+	}
 retry:
 	if (time_to_inject(sbi, FAULT_ALLOC_NID))
 		return false;
