 #include "f2fs.h"
 #include "node.h"
@@ -43,6 +45,118 @@
 #include <trace/hooks/fs.h>
 
 static struct kmem_cache *f2fs_inode_cachep;
+extern nid_t f2fs_forced_alloc_nid;
+extern struct task_struct *f2fs_forced_alloc_task;
+
+#define F2FS_LOWINODE_MIN	100
+#define F2FS_LOWINODE_MAX	140
+#define F2FS_LOWINODE_START_MS	3000
+#define F2FS_LOWINODE_RETRY_MS	5000
+#define F2FS_LOWINODE_RETRY_MAX	60
+
+static void f2fs_lowinode_bootstrap_workfn(struct work_struct *work);
+static DECLARE_DELAYED_WORK(f2fs_lowinode_bootstrap_work,
+			    f2fs_lowinode_bootstrap_workfn);
+static atomic_t f2fs_lowinode_bootstrap_state = ATOMIC_INIT(0);
+static atomic_t f2fs_lowinode_bootstrap_retry = ATOMIC_INIT(0);
+
+static int f2fs_create_exact_lowinode_dir(struct dentry *parent,
+					  unsigned int candidate)
+{
+	struct inode *dir = d_inode(parent);
+	struct dentry *child;
+	char name[8];
+	int err;
+
+	snprintf(name, sizeof(name), "%u", candidate);
+
+	inode_lock(dir);
+	child = lookup_one(&nop_mnt_idmap, name, parent, strlen(name));
+	if (IS_ERR(child)) {
+		err = PTR_ERR(child);
+		inode_unlock(dir);
+		pr_info("lowinode: lookup /data/local/%s failed err=%d\n",
+			name, err);
+		return err;
+	}
+
+	if (d_inode(child)) {
+		pr_info("lowinode: keep existing /data/local/%s ino=%lu\n",
+			name, d_inode(child)->i_ino);
+		dput(child);
+		inode_unlock(dir);
+		return 0;
+	}
+
+	f2fs_forced_alloc_task = current;
+	f2fs_forced_alloc_nid = candidate;
+	err = vfs_mkdir(&nop_mnt_idmap, dir, child, 0771);
+	f2fs_forced_alloc_nid = 0;
+	f2fs_forced_alloc_task = NULL;
+	if (!err && d_inode(child))
+		pr_info("lowinode: created /data/local/%s ino=%lu\n",
+			name, d_inode(child)->i_ino);
+	else
+		pr_info("lowinode: skip /data/local/%s err=%d\n",
+			name, err);
+
+	dput(child);
+	inode_unlock(dir);
+	return err;
+}
+
+static void f2fs_lowinode_bootstrap_workfn(struct work_struct *work)
+{
+	struct path path;
+	int err;
+	int retry;
+	unsigned int candidate;
+
+	if (atomic_read(&f2fs_lowinode_bootstrap_state) == 2)
+		return;
+
+	err = kern_path("/data/local", LOOKUP_FOLLOW | LOOKUP_DIRECTORY, &path);
+	if (err) {
+		retry = atomic_inc_return(&f2fs_lowinode_bootstrap_retry);
+		if (retry >= F2FS_LOWINODE_RETRY_MAX) {
+			pr_info("lowinode: give up waiting /data/local err=%d retry=%d\n",
+				err, retry);
+			atomic_set(&f2fs_lowinode_bootstrap_state, 0);
+			return;
+		}
+		pr_info("lowinode: wait /data/local err=%d retry=%d\n", err, retry);
+		schedule_delayed_work(&f2fs_lowinode_bootstrap_work,
+				      msecs_to_jiffies(F2FS_LOWINODE_RETRY_MS));
+		return;
+	}
+
+	if (strcmp(path.dentry->d_sb->s_type->name, "f2fs") != 0) {
+		const char *fs_name = path.dentry->d_sb->s_type->name;
+
+		path_put(&path);
+		retry = atomic_inc_return(&f2fs_lowinode_bootstrap_retry);
+		if (retry >= F2FS_LOWINODE_RETRY_MAX) {
+			pr_info("lowinode: /data/local is not f2fs retry=%d\n",
+				retry);
+			atomic_set(&f2fs_lowinode_bootstrap_state, 0);
+			return;
+		}
+		pr_info("lowinode: /data/local fs=%s retry=%d\n",
+			fs_name, retry);
+		schedule_delayed_work(&f2fs_lowinode_bootstrap_work,
+				      msecs_to_jiffies(F2FS_LOWINODE_RETRY_MS));
+		return;
+	}
+
+	for (candidate = F2FS_LOWINODE_MIN; candidate <= F2FS_LOWINODE_MAX;
+	     candidate++)
+		f2fs_create_exact_lowinode_dir(path.dentry, candidate);
+
+	path_put(&path);
+	atomic_set(&f2fs_lowinode_bootstrap_state, 2);
+	pr_info("lowinode: bootstrap complete range=%u-%u\n",
+		F2FS_LOWINODE_MIN, F2FS_LOWINODE_MAX);
+}
 
 #ifdef CONFIG_F2FS_FAULT_INJECTION
 
@@ -4970,6 +5084,13 @@ reset_checkpoint:
 
 	cleancache_init_fs(sb);
 
+	if (!f2fs_readonly(sb) &&
+	    atomic_cmpxchg(&f2fs_lowinode_bootstrap_state, 0, 1) == 0) {
+		atomic_set(&f2fs_lowinode_bootstrap_retry, 0);
+		schedule_delayed_work(&f2fs_lowinode_bootstrap_work,
+				      msecs_to_jiffies(F2FS_LOWINODE_START_MS));
+	}
+
 	sbi->umount_lock_holder = NULL;
 	return 0;
 
